{
  "name": "semantic-zoom-mindmap",
  "version": "1.0.0",
  "description": "Semantic Zoom Mindmap plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --external:obsidian --outfile=main.js --format=cjs --platform=node --watch",
